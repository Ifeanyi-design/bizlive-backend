FLASK_ENV=development
SECRET_KEY=change-me
DATABASE_URL=postgresql://neondb_owner:password@ep-example.us-east-1.aws.neon.tech/bizlive?sslmode=require
CORS_ORIGINS=*
SOCKETIO_ASYNC_MODE=gevent
AUTO_CREATE_TABLES=1
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_TOKEN_TTL_SECONDS=14400
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret
GOOGLE_OAUTH_CALLBACK_URL=https://your-backend-host/api/auth/google/callback
